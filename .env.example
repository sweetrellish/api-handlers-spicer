# CompanyCam API configuration
COMPANYCAM_WEBHOOK_TOKEN=replace_with_companycam_api_token
COMPANYCAM_BASE_URL=https://api.companycam.com

# Webhook hardening (set this value when creating webhook via API)
COMPANYCAM_WEBHOOK_SECRET=replace_with_random_shared_secret
WEBHOOK_SIGNATURE_HEADER=X-CompanyCam-Signature
WEBHOOK_TOKEN_FIELD=token
WEBHOOK_AUTH_REQUIRED=True

# MarketSharp API configuration
# Mode: auto, odata_readonly, odata_write, or rest_write
MARKETSHARP_MODE=odata_readonly

# OData read-only credentials from MarketSharp API Maintenance page
MARKETSHARP_COMPANY_ID=replace_with_company_id
MARKETSHARP_USER_KEY=replace_with_user_key
MARKETSHARP_SECRET_KEY=replace_with_secret_key
MARKETSHARP_ODATA_URL=https://api4.marketsharpm.com/WcfDataService.svc
MARKETSHARP_NOTE_CONTACT_TYPE=Contact

# Optional REST write mode (only if MarketSharp enables write API for your account)
MARKETSHARP_API_KEY=
MARKETSHARP_BASE_URL=

# Runtime configuration
FLASK_PORT=5001
FLASK_DEBUG=False
IDEMPOTENCY_DB_PATH=cc_webhook_dedupe.db
PENDING_QUEUE_DB_PATH=pending_comments.db

# Optional queue UI poster worker (when API write is blocked)
QUEUE_WORKER_BATCH_SIZE=5
QUEUE_WORKER_POLL_SECONDS=20
QUEUE_PROCESSING_TIMEOUT_SECONDS=300
QUEUE_UNMATCHED_RETRY_SECONDS=3600
QUEUE_UNMATCHED_DUMP_PATH=unmatched_comments.jsonl
MARKETSHARP_UI_CONTACT_URL_MAP_FILE=marketsharp_contact_mappings.json
MARKETSHARP_UI_CONTACT_URL_MAP={}
MARKETSHARP_UI_BASE_URL=https://app.marketsharp.com
MARKETSHARP_UI_USER_DATA_DIR=.marketsharp-profile
MARKETSHARP_UI_HEADLESS=False
MARKETSHARP_UI_LOGIN_CHECK_SELECTOR=
MARKETSHARP_UI_SEARCH_SELECTOR=
MARKETSHARP_UI_FIRST_RESULT_SELECTOR=
MARKETSHARP_UI_NOTES_TAB_SELECTOR=
MARKETSHARP_UI_NOTE_BUTTON_SELECTOR=
MARKETSHARP_UI_NOTE_INPUT_SELECTOR=
MARKETSHARP_UI_NOTE_SAVE_SELECTOR=
